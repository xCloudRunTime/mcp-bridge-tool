# =============================================================
# mcp-bridge-tool — Environment Variables Template
# =============================================================
# Is file ko copy karke ".env" naam de do:
#   cp .env.example .env
# Phir apni real values bharo.
# IMPORTANT: .env file kabhi bhi Git mein commit mat karo!
# =============================================================

# ── GitHub ──────────────────────────────────────────────────
# GitHub Personal Access Token (PAT)
# Kahan se banate hain:
#   GitHub → Settings → Developer settings → Personal access tokens → Tokens (classic)
# Required scopes: repo (full) — ya sirf `repo:read` agar sirf read karna hai
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── GitLab ──────────────────────────────────────────────────
# GitLab Personal Access Token
# Kahan se banate hain:
#   GitLab → User Settings → Access Tokens
# Required scopes: read_api
GITLAB_TOKEN=glpat-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# GitLab self-hosted instance ka URL (agar gitlab.com use kar rahe ho toh yeh line remove karo)
# GITLAB_BASE_URL=https://gitlab.your-company.com

# ── Jira Cloud ───────────────────────────────────────────────
# Aapki Jira instance ka base URL
JIRA_BASE_URL=https://your-company.atlassian.net

# Jira mein login karne wala email
JIRA_EMAIL=you@yourcompany.com

# Jira API Token (password nahi!)
# Kahan se banate hain:
#   https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=ATATT3xFfGF0xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Optional: Custom Jira Field IDs ─────────────────────────
# Har company ke Jira mein custom fields ki IDs alag hoti hain.
# Apni field IDs jaanne ke liye:
#   GET https://your-company.atlassian.net/rest/api/3/field
# Phir woh IDs niche set karo:
# JIRA_AC_FIELD_ID=customfield_10106   # Acceptance Criteria
# JIRA_SP_FIELD_ID=customfield_10016   # Story Points

# ── AWS DynamoDB ─────────────────────────────────────────────
# Kahan se banate hain:
#   AWS Console → IAM → Users → Create user → Attach policy: AmazonDynamoDBFullAccess
#   Phir "Security credentials" tab mein "Create access key" karo.

AWS_REGION=ap-south-1

# IAM User ki credentials
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY

# DynamoDB table ka naam (default: mcp-mr-analysis)
# DDB_TABLE_NAME=mcp-mr-analysis

# Local DynamoDB testing ke liye (DynamoDB Local Docker image)
# DDB_ENDPOINT=http://localhost:8000

# ── Analyst Identity ──────────────────────────────────────────
# Jab analysis save hoga toh yeh naam "analyst" field mein jayega.
# Har team member apna unique naam yahan set kare.
ANALYST_NAME=ravi.sharma

# ── Slack (Optional) ──────────────────────────────────────────
# post_review_to_slack tool ke liye.
# Incoming Webhook URL banao:
#   https://api.slack.com/apps → Create App → Incoming Webhooks → Activate → Add New Webhook
# Webhook URL is tarah dikhai deta hai: https://hooks.slack.com/services/T.../B.../...
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/<WORKSPACE_ID>/<APP_ID>/<TOKEN>

# ── Google Sheets & Drive (Optional) ─────────────────────────
# export_to_google_sheets aur save_report_to_drive tools ke liye.
#
# Setup steps:
#   1. Google Cloud Console mein project banao aur Sheets + Drive APIs enable karo.
#   2. IAM → Service Accounts → Create → JSON key download karo.
#   3. Apni Google Sheet aur Drive folder ko service account email se share karo.
#
# Service account JSON ka poora content yahan paste karo (single line mein):
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"your-project",...}

# Google Sheets spreadsheet ID (URL mein milta hai: /spreadsheets/d/<ID>/edit)
GOOGLE_SHEET_ID=1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs74OgVE2upms

# Google Drive folder ID (folder URL mein milta hai: /drive/folders/<ID>)
GOOGLE_DRIVE_FOLDER_ID=1A2B3C4D5E6F7G8H9I0J
