{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build",
      "type": "shell",
      "command": "npm run build",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "silent",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": "$tsc"
    },
    {
      "label": "Build: Watch",
      "type": "shell",
      "command": "npm run watch",
      "group": "build",
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": "$tsc-watch"
    },
    {
      "label": "Start MCP Server",
      "type": "shell",
      "command": "npm run start",
      "group": "none",
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "Test: DynamoDB Connection",
      "type": "shell",
      "command": "npm run test:ddb",
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "Docker: Start Local DynamoDB",
      "type": "shell",
      "command": "docker compose up -d && echo 'DynamoDB: http://localhost:8000  |  Admin UI: http://localhost:8001'",
      "group": "none",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": false
      },
      "problemMatcher": []
    },
    {
      "label": "Docker: Stop Local DynamoDB",
      "type": "shell",
      "command": "docker compose down",
      "group": "none",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": false
      },
      "problemMatcher": []
    },
    {
      "label": "Build + Test DDB",
      "dependsOrder": "sequence",
      "dependsOn": ["Build", "Test: DynamoDB Connection"],
      "group": "none",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    }
  ]
}
