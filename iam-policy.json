{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "McpBridgeToolDynamoDB",
      "Effect": "Allow",
      "Action": [
        "dynamodb:CreateTable",
        "dynamodb:DescribeTable",
        "dynamodb:PutItem",
        "dynamodb:GetItem",
        "dynamodb:Query",
        "dynamodb:Scan",
        "dynamodb:DeleteItem",
        "dynamodb:UpdateItem"
      ],
      "Resource": [
        "arn:aws:dynamodb:*:*:table/mcp-mr-analysis",
        "arn:aws:dynamodb:*:*:table/mcp-mr-analysis/index/*"
      ]
    },
    {
      "Sid": "McpBridgeToolListTables",
      "Effect": "Allow",
      "Action": [
        "dynamodb:ListTables"
      ],
      "Resource": "*"
    }
  ]
}
